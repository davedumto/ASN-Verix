# Verix environment example

# APP_MODE: demo | local | production
APP_MODE=local

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agent_network

# Encryption
ENCRYPTION_KEY=

# AI providers
CLAUDE_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Stellar / Soroban
COORDINATOR_STELLAR_PUBLIC_KEY=G...
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet
STELLAR_USDC_CODE=USDC
STELLAR_USDC_ISSUER=G...
SOROBAN_AGENT_REGISTRY_CONTRACT_ID=C...
SOROBAN_RECEIPT_ANCHOR_CONTRACT_ID=C...

# Trustless Work
# ESCROW_MODE: disabled | demo | live
ESCROW_MODE=demo
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=
TRUSTLESS_WORK_SIGNER_ADDRESS=G...
TRUSTLESS_WORK_ESCROW_TYPE=multi-release

# TRUSTLESS_WORK_SIGNING_MODE:
#   server — server signs XDR using COORDINATOR_STELLAR_PRIVATE_KEY (requires key below)
#   wallet — unsigned XDR is returned to the frontend; user signs with Albedo / Freighter
TRUSTLESS_WORK_SIGNING_MODE=wallet

# Required when TRUSTLESS_WORK_SIGNING_MODE=server OR for automated milestone release in live mode.
# Export from Albedo → Account Settings → Show secret key (starts with S).
# Safe for testnet; never use a mainnet key here.
COORDINATOR_STELLAR_PRIVATE_KEY=S...

NEXT_PUBLIC_TRUSTLESS_WORK_VIEWER_URL=https://viewer.trustlesswork.com

# Proofs
PROOF_MODE=local
COORDINATOR_CONCURRENCY_LIMIT=2
COORDINATOR_DELEGATION_MAX_DEPTH=1

# Optional admin bypass token for demo cleanup
ADMIN_SECRET=
