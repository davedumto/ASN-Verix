# ─────────────────────────────────────────────────────────────────────────────
# Agent Specialization Network — Environment Configuration
#
# Copy this file to .env.local and fill in the values that apply to your mode.
#
# APP_MODE controls validation strictness:
#   demo        No DATABASE_URL or wallet keys needed — everything is mocked.
#               Great for exploring the UI without any external services.
#   local       DATABASE_URL required; AI + blockchain keys optional (mock fallback).
#               Default when DATABASE_URL is present in dev.
#   production  DATABASE_URL, ENCRYPTION_KEY, and all wallet keys are required.
#               Auto-selected when NODE_ENV=production.
#
# To start in demo mode without configuring anything:
#   APP_MODE=demo npm run dev
# ─────────────────────────────────────────────────────────────────────────────

# Uncomment to override auto-detection (demo | local | production)
# APP_MODE=local


# ── Database ──────────────────────────────────────────────────────────────────
# Required in: local, production
# Not needed in demo mode.
DATABASE_URL=postgresql://user:password@localhost:5432/agent_network


# ── Encryption ────────────────────────────────────────────────────────────────
# Required in: production  (startup will refuse to boot without it)
# Optional in: local       (a dev-only default is used — DO NOT use in production)
#
# Generate a strong key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=


# ── AI APIs ───────────────────────────────────────────────────────────────────
# Optional in all modes. When absent the coordinator falls back to mock responses,
# which are clearly labeled "[demo mode]" in the activity feed.
CLAUDE_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...


# ── Coordinator Wallet ────────────────────────────────────────────────────────
# Required in: production
# Optional in: local, demo  (blockchain payments are skipped when absent)
#
# This wallet pays the specialist agents. It must hold USDC on SKALE Calypso
# Hub Testnet and enough sFUEL for gas (gasless — sFUEL amount is minimal).
COORDINATOR_PRIVATE_KEY=0x...


# ── Specialist Wallets ────────────────────────────────────────────────────────
# Required in: production
# Optional in: local, demo  (payments are mocked when absent)
CODE_AUDITOR_PRIVATE_KEY=0x...
MARKET_ANALYST_PRIVATE_KEY=0x...
CREATIVE_WRITER_PRIVATE_KEY=0x...


# ── SKALE / Blockchain ────────────────────────────────────────────────────────
# All optional — sensible testnet defaults are built into the app.

# Override the default SKALE Calypso Hub Testnet RPC endpoint.
# SKALE_RPC_URL=https://974399131.rpc.thirdweb.com

# USDC ERC-20 contract address on SKALE Calypso Hub Testnet (6 decimals).
# USDC_CONTRACT_ADDRESS=0x4E2B3DD08B71F45Bb4bcfAE425D697c650e4212B

# Thirdweb project secret key — enables authenticated RPC with higher rate limits.
# THIRDWEB_SECRET_KEY=
