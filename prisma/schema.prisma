generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          String   @id @default(cuid())
  description String
  status      String   @default("pending")
  result      Json?
  totalCost   Decimal?
  spendCap    Decimal?
  events      Json?    @default("[]")
  ownerId     String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  subtasks    Subtask[]
  payments    Payment[]
  jobs        Job[]
}

model Subtask {
  id             String   @id @default(cuid())
  taskId         String
  capability     String
  specialistId   String?
  specialistName String?
  status         String   @default("pending")
  cost           Decimal?
  result         String?
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  task       Task       @relation(fields: [taskId], references: [id])
  specialist Specialist? @relation(fields: [specialistId], references: [id])
}

model Specialist {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String
  endpoint      String
  walletAddress String
  capabilities  String[]
  priceUsdc     Decimal
  reputation    Int      @default(50)
  totalJobs     Int      @default(0)
  status        String   @default("online")
  aiModel       String?  @default("openai")
  apiKey        String?
  apiKeyMasked  String?
  ownerId       String?
  createdAt     DateTime @default(now())

  subtasks Subtask[]
  payments Payment[]
}

model Payment {
  id           String   @id @default(cuid())
  taskId       String
  specialistId String
  amount       Decimal
  currency     String   @default("USDC")
  txHash       String?
  blockNumber  Int?
  fromAddress  String?
  toAddress    String?
  status       String   @default("pending")
  protocol     String   @default("x402")
  createdAt    DateTime @default(now())
  confirmedAt  DateTime?

  task       Task       @relation(fields: [taskId], references: [id])
  specialist Specialist @relation(fields: [specialistId], references: [id])
}

model Reputation {
  id           String @id @default(cuid())
  specialistId String @unique
  score        Int    @default(50)
  totalRatings Int    @default(0)
  updatedAt    DateTime @updatedAt
}

/**
 * Durable job boundary for long-running background work.
 *
 * A Job wraps a single unit of background execution (coordinator run, proof
 * generation, escrow sync) and survives process restarts. Status transitions:
 *   queued → running → completed
 *                    ↘ failed (retried up to maxAttempts)
 *
 * Atomic claiming: UPDATE WHERE status='queued' prevents double-execution
 * when two processes race to start the same job.
 */
model Job {
  id          String    @id @default(cuid())
  /// JobType: "coordinator_execution" | "proof_generation" | "escrow_sync"
  type        String
  /// JobStatus: "queued" | "running" | "completed" | "failed"
  status      String    @default("queued")
  taskId      String?
  payload     Json
  result      Json?
  errorMsg    String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([status, type])
}
