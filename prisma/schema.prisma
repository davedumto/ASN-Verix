generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          String   @id @default(cuid())
  description String
  status      String   @default("pending")
  result      Json?
  totalCost   Decimal?
  spendCap    Decimal?
  events      Json?    @default("[]")
  ownerId     String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  subtasks    Subtask[]
  payments    Payment[]
  jobs        Job[]
}

model Subtask {
  id             String   @id @default(cuid())
  taskId         String
  capability     String
  specialistId   String?
  specialistName String?
  status         String   @default("pending")
  cost           Decimal?
  result         String?
  agentVersionId String?
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  task         Task          @relation(fields: [taskId], references: [id])
  specialist   Specialist?   @relation(fields: [specialistId], references: [id])
  agentVersion AgentVersion? @relation(fields: [agentVersionId], references: [id])
}

model Specialist {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String
  endpoint       String
  walletAddress  String
  capabilities   String[]
  priceUsdc      Decimal
  reputation     Int      @default(50)
  totalJobs      Int      @default(0)
  status         String   @default("online")
  aiModel        String?  @default("openai")
  apiKey         String?
  apiKeyMasked   String?
  ownerId        String?
  /// ProofPolicy: "trace-only" | "receipt-proof" | "escrow-eligible"
  proofPolicy    String   @default("trace-only")
  currentVersion Int      @default(1)
  createdAt      DateTime @default(now())

  subtasks Subtask[]
  payments Payment[]
  versions AgentVersion[]
}

model Payment {
  id           String   @id @default(cuid())
  taskId       String
  specialistId String
  amount       Decimal
  currency     String   @default("USDC")
  txHash       String?
  blockNumber  Int?
  fromAddress  String?
  toAddress    String?
  status       String   @default("pending")
  protocol     String   @default("x402")
  createdAt    DateTime @default(now())
  confirmedAt  DateTime?

  task       Task       @relation(fields: [taskId], references: [id])
  specialist Specialist @relation(fields: [specialistId], references: [id])
}

model Reputation {
  id           String   @id @default(cuid())
  specialistId String   @unique
  score        Int      @default(50)
  totalRatings Int      @default(0)
  updatedAt    DateTime @updatedAt
}

/**
 * Immutable snapshot of specialist metadata at publication time.
 *
 * Every time agent price, capabilities, wallet, or proof policy changes,
 * a new version row is created. Subtasks reference the version that was
 * active at invocation so receipts can prove the exact metadata used.
 *
 * versionHash is SHA-256(name|version|price|wallet|capabilities|proofPolicy)
 * computed deterministically so it can be included in receipt hashes.
 */
model AgentVersion {
  id            String   @id @default(cuid())
  specialistId  String
  version       Int
  name          String
  description   String
  walletAddress String
  capabilities  String[]
  priceUsdc     Decimal
  proofPolicy   String
  aiModel       String
  versionHash   String
  createdAt     DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  subtasks   Subtask[]

  @@unique([specialistId, version])
  @@index([specialistId])
}

/**
 * Receipt-backed reputation events.
 *
 * Only verified executions affect the verified stats shown in the marketplace.
 * Demo completions are tracked separately and labeled distinctly in the UI.
 * The score field stores the impact (+1 success, -1 failure) for aggregation.
 */
model ReputationEvent {
  id           String   @id @default(cuid())
  specialistId String
  taskId       String?
  /// EventType: "verified_completion" | "demo_completion" | "failure"
  type         String
  score        Int
  verified     Boolean  @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([specialistId])
  @@index([specialistId, verified])
}

/**
 * Durable job boundary for long-running background work.
 *
 * A Job wraps a single unit of background execution (coordinator run, proof
 * generation, escrow sync) and survives process restarts. Status transitions:
 *   queued → running → completed
 *                    ↘ failed (retried up to maxAttempts)
 *
 * Atomic claiming: UPDATE WHERE status='queued' prevents double-execution
 * when two processes race to start the same job.
 */
model Job {
  id          String    @id @default(cuid())
  /// JobType: "coordinator_execution" | "proof_generation" | "escrow_sync"
  type        String
  /// JobStatus: "queued" | "running" | "completed" | "failed"
  status      String    @default("queued")
  taskId      String?
  payload     Json
  result      Json?
  errorMsg    String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([status, type])
}
