generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          String   @id @default(cuid())
  description String
  status      String   @default("pending")
  result      Json?
  totalCost   Decimal?
  spendCap    Decimal?
  events      Json?    @default("[]")
  ownerId     String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  subtasks     Subtask[]
  payments     Payment[]
  jobs         Job[]
  traceEvents  ExecutionTraceEvent[]
  receipt      ExecutionReceipt?
  escrow       Escrow?
  proofs       Proof[]
}

model Subtask {
  id             String   @id @default(cuid())
  taskId         String
  capability     String
  specialistId   String?
  specialistName String?
  status         String   @default("pending")
  cost           Decimal?
  result         String?
  agentVersionId String?
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  task         Task          @relation(fields: [taskId], references: [id])
  specialist   Specialist?   @relation(fields: [specialistId], references: [id])
  agentVersion AgentVersion? @relation(fields: [agentVersionId], references: [id])
}

model Specialist {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String
  endpoint       String
  walletAddress  String
  capabilities   String[]
  priceUsdc      Decimal
  reputation     Int      @default(50)
  totalJobs      Int      @default(0)
  status         String   @default("online")
  aiModel        String?  @default("openai")
  apiKey         String?
  apiKeyMasked   String?
  ownerId        String?
  /// ProofPolicy: "trace-only" | "receipt-proof" | "escrow-eligible"
  proofPolicy    String   @default("trace-only")
  currentVersion Int      @default(1)
  createdAt      DateTime @default(now())

  subtasks Subtask[]
  payments Payment[]
  versions AgentVersion[]
}

model Payment {
  id           String   @id @default(cuid())
  taskId       String
  specialistId String
  amount       Decimal
  currency     String   @default("USDC")
  txHash       String?
  blockNumber  Int?
  fromAddress  String?
  toAddress    String?
  status       String   @default("pending")
  protocol     String   @default("trustless_work")
  createdAt    DateTime @default(now())
  confirmedAt  DateTime?

  task       Task       @relation(fields: [taskId], references: [id])
  specialist Specialist @relation(fields: [specialistId], references: [id])
}

model Reputation {
  id           String   @id @default(cuid())
  specialistId String   @unique
  score        Int      @default(50)
  totalRatings Int      @default(0)
  updatedAt    DateTime @updatedAt
}

/**
 * Immutable snapshot of specialist metadata at publication time.
 *
 * Every time agent price, capabilities, wallet, or proof policy changes,
 * a new version row is created. Subtasks reference the version that was
 * active at invocation so receipts can prove the exact metadata used.
 *
 * versionHash is SHA-256(name|version|price|wallet|capabilities|proofPolicy)
 * computed deterministically so it can be included in receipt hashes.
 */
model AgentVersion {
  id            String   @id @default(cuid())
  specialistId  String
  version       Int
  name          String
  description   String
  walletAddress String
  capabilities  String[]
  priceUsdc     Decimal
  proofPolicy   String
  aiModel       String
  versionHash   String
  createdAt     DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  subtasks   Subtask[]

  @@unique([specialistId, version])
  @@index([specialistId])
}

/**
 * Receipt-backed reputation events.
 *
 * Only verified executions affect the verified stats shown in the marketplace.
 * Demo completions are tracked separately and labeled distinctly in the UI.
 * The score field stores the impact (+1 success, -1 failure) for aggregation.
 */
model ReputationEvent {
  id           String   @id @default(cuid())
  specialistId String
  taskId       String?
  /// EventType: "verified_completion" | "demo_completion" | "failure"
  type         String
  score        Int
  verified     Boolean  @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([specialistId])
  @@index([specialistId, verified])
}

/**
 * Structured, hash-chained trace event for a single execution step.
 *
 * Every meaningful coordinator action (routing, payment, specialist execution,
 * lifecycle transitions) is recorded as a trace event. Events are chained via
 * prevEventHash so the final eventHash of the last event serves as the trace
 * root — any mutation to an earlier event changes all subsequent hashes.
 *
 * eventHash = SHA-256(taskId | sequence | eventType | actor | inputHash |
 *                     outputHash | prevEventHash)
 */
model ExecutionTraceEvent {
  id            String   @id @default(cuid())
  taskId        String
  sequence      Int
  /// TraceEventType: coordinator_start | task_decomposed | spend_cap_check |
  ///   spend_cap_exceeded | specialist_assigned | payment_initiated |
  ///   payment_confirmed | payment_failed | specialist_invoked |
  ///   specialist_completed | specialist_failed | task_completed | task_failed
  eventType     String
  actor         String
  displayMessage String
  inputHash     String?
  outputHash    String?
  eventHash     String
  prevEventHash String?
  metadata      Json?
  timestamp     DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, sequence])
  @@index([taskId])
}

/**
 * Canonical receipt for a completed execution.
 *
 * Commits to task input, selected agent version snapshots, spend cap, total
 * cost, the trace root, output summary, and all on-chain payment entries.
 * receiptHash = SHA-256(canonical JSON of the receipt fields).
 *
 * The receipt is the artifact that downstream proof and escrow systems consume.
 * status starts as "proof_ready" once all trace events exist.
 */
model ExecutionReceipt {
  id                 String   @id @default(cuid())
  taskId             String   @unique
  taskInputHash      String
  agentVersionHashes String[]
  spendCap           Decimal?
  totalCost          Decimal?
  traceRoot          String
  outputHash         String?
  registrySnapshotHash String?
  anchorContractId   String?
  anchorTxHash       String?
  anchoredAt         DateTime?
  paymentSummary     Json
  receiptHash        String
  /// ReceiptStatus: "pending" | "proof_ready" | "verified"
  status             String   @default("proof_ready")
  createdAt          DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

/**
 * Durable job boundary for long-running background work.
 *
 * A Job wraps a single unit of background execution (coordinator run, proof
 * generation, escrow sync) and survives process restarts. Status transitions:
 *   queued → running → completed
 *                    ↘ failed (retried up to maxAttempts)
 *
 * Atomic claiming: UPDATE WHERE status='queued' prevents double-execution
 * when two processes race to start the same job.
 */
model Job {
  id          String    @id @default(cuid())
  /// JobType: "coordinator_execution" | "proof_generation" | "escrow_sync"
  type        String
  /// JobStatus: "queued" | "running" | "completed" | "failed"
  status      String    @default("queued")
  taskId      String?
  payload     Json
  result      Json?
  errorMsg    String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([status, type])
}

/**
 * Top-level escrow record for a task execution.
 *
 * Created after spend cap passes when ESCROW_MODE != "disabled".
 * externalId is the Trustless Work escrow ID (null in demo mode uses DEMO- prefix).
 * Each subtask maps to one EscrowMilestone.
 *
 * EscrowStatus: pending | funded | in_progress | completed | cancelled | disputed
 */
model Escrow {
  id             String    @id @default(cuid())
  taskId         String    @unique
  externalId     String?
  /// EscrowStatus: pending | funded | in_progress | completed | cancelled | disputed
  status         String    @default("pending")
  totalAmount    Decimal
  currency       String    @default("USDC")
  payerAddress   String
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  task       Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  milestones EscrowMilestone[]

  @@index([taskId])
  @@index([status])
}

/**
 * One milestone per specialist subtask.
 *
 * releaseCondition controls what gate must pass before releaseMilestone() is called:
 *   proof_verified — requires ExecutionReceipt.status === "verified"
 *   receipt_ready  — requires ExecutionReceipt to exist
 *   manual         — coordinator triggers release explicitly
 *   auto           — released immediately after specialist completes (demo)
 *
 * MilestoneStatus: pending | funded | in_progress | released | refunded | failed
 */
model EscrowMilestone {
  id                   String    @id @default(cuid())
  escrowId             String
  subtaskId            String?
  specialistId         String
  recipientAddress     String
  amount               Decimal
  /// MilestoneStatus: pending | funded | in_progress | released | refunded | failed
  status               String    @default("pending")
  /// ReleaseCondition: proof_verified | receipt_ready | manual | auto
  releaseCondition     String    @default("auto")
  agentVersionId       String?
  agentVersionHash     String?
  receiptId            String?
  releaseTxHash        String?
  externalMilestoneId  String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  escrow Escrow @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId])
  @@index([status])
  @@index([subtaskId])
}

/**
 * Proof record for a completed execution receipt.
 *
 * Tracks the lifecycle of a proof job: queued by receipt service, run by
 * the deterministic TypeScript verifier (local) or Boundless/RISC Zero (live).
 *
 * ProofStatus: pending | running | proven | verified | failed
 *
 * journal is the ProofJournal JSON produced by the verifier — 5 boolean
 * constraints that a verifier can check without re-running the full trace.
 */
model Proof {
  id            String    @id @default(cuid())
  receiptId     String    @unique
  taskId        String
  receiptHash   String
  schemaVersion String    @default("1.0")
  /// ProofStatus: pending | running | proven | verified | failed
  status        String    @default("pending")
  programId     String?
  journal       Json?
  artifactUri   String?
  errorMsg      String?
  createdAt     DateTime  @default(now())
  provenAt      DateTime?
  verifiedAt    DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([receiptId])
  @@index([status])
}
